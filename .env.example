# ==========================================
# OJARA — ENVIRONMENT VARIABLES
# Copy to .env.local and fill in. Never commit .env.local.
# ==========================================

# --- Wix Headless: OAuth (browser-safe, public) ---
# Wix Dashboard → Headless → OAuth Apps → create client
NEXT_PUBLIC_WIX_CLIENT_ID=

# --- Wix Headless: Admin API key (SERVER ONLY — never exposed to the browser) ---
# Creates/approves orders, applies draft-order discounts, marks payments.
# Wix Dashboard → Settings → API Keys
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Email notifications (nodemailer over Gmail SMTP) ---
# GMAIL_APP_PASSWORD must be a Google *App Password* (requires 2FA enabled).
GMAIL_USER=
GMAIL_APP_PASSWORD=
SUPPORT_EMAIL=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# SEO / ANALYTICS / TRACKING
# ==========================================

# --- Google Tag Manager (client) ---
# Paste your container id. GA4, Clarity, and the Meta Pixel are configured INSIDE
# the GTM dashboard — nothing else to set here for those.
# GTM → Admin → Container → "GTM-XXXXXXX"
NEXT_PUBLIC_GTM_ID=

# --- Meta Conversions API (server-side; token is NEVER exposed to the browser) ---
# Meta Events Manager → Data Sources → your pixel → Settings.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional: shows events under Events Manager → Test Events while you verify.
META_TEST_EVENT_CODE=

# --- Search engine verification (server-rendered <meta> tags) ---
# Google Search Console → Settings → Ownership verification → HTML tag (content value).
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → Verify → Meta tag (the msvalidate.01 content value).
BING_SITE_VERIFICATION=
